<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-4 shadow-lg p-4 rounded bg-light border-top border-primary border-4">
            <h2 class="text-center mb-4">Venta de Garage</h2>
            <p class="text-muted text-center">Ingresa para vender tus productos</p>
            <form action="/api/auth/login" method="POST">
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" required>
                </div>
                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input type="password" name="password" class="form-control" required>
                </div>
                <button type="submit" class="btn btn-success w-100">Entrar</button>
            </form>
            <hr>
            <div class="text-center">
                <small>¿Eres nuevo? <a href="/register">Regístrate</a></small>
            </div>
        </div>
    </div>
</div>