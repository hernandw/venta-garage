<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Editar Producto: {{producto.nombre}}</h3>
                </div>
                <div class="card-body p-4">
                    <form action="/api/productos/edit/{{producto.id}}" method="POST" enctype="multipart/form-data">

                        <input type="hidden" name="url_actual" value="{{producto.url_imagen}}">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre del Producto</label>
                            <input type="text" name="nombre" class="form-control" value="{{producto.nombre}}" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Precio Original</label>
                                <input type="number" name="precio_original" class="form-control"
                                    value="{{producto.precio_original}}" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Precio Oferta</label>
                                <input type="number" name="precio_oferta" class="form-control"
                                    value="{{producto.precio_oferta}}" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Descripción</label>
                            <textarea name="descripcion" class="form-control" rows="4"
                                required>{{producto.descripcion}}</textarea>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Imagen del Producto</label>
                            <div class="mb-2">
                                <small class="text-muted d-block mb-1">Imagen actual:</small>
                                <img src="{{producto.url_imagen}}" alt="Vista previa" class="img-thumbnail"
                                    style="height: 100px;">
                            </div>
                            <input type="file" name="foto" class="form-control" accept="image/*">
                            <div class="form-text">Si no seleccionas un archivo, se mantendrá la imagen actual.</div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 border-top pt-3">
                            <a href="/admin" class="btn btn-light border">Cancelar</a>
                            <button type="submit" class="btn btn-primary px-4">Guardar Cambios</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>