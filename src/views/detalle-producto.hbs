<div class="container mt-5">
    <div class="row">
        <div class="col-md-6">
            <img src="{{producto.url_imagen}}" class="img-fluid rounded shadow">
        </div>
        <div class="col-md-6">
            <h1>{{producto.nombre}}</h1>
            <p class="text-muted">Publicado por: {{producto.vendedor}}</p>
            <h3 class="text-success">$ {{producto.precio_oferta}}</h3>
            <p>{{producto.descripcion}}</p>
            <a href="/" class="btn btn-secondary">Volver al inicio</a>
        </div>
    </div>
</div>